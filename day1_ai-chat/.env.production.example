# AI Chat — Production Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.production.example .env

# --- LLM API Keys (at least one recommended) ---

# DeepSeek API key (for DeepSeek Chat model)
# Get one at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# OpenRouter API key (for free cloud models like Nemotron, Gemma, etc.)
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Ollama (auto-configured by Docker Compose) ---
# OLLAMA_HOST is set automatically to http://ollama:11434
# Do NOT set it here unless you're running Ollama outside Docker
